{
  "name": "rbabikerentals-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx --tsconfig backend/tsconfig.json backend/src/server.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p backend/tsconfig.json && tsc-alias -p backend/tsconfig.json",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "start": "node backend/dist/server.js",
    "typecheck": "tsc -p backend/tsconfig.json --noEmit && tsc -p frontend/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx --tsconfig backend/tsconfig.json scripts/migrate.ts",
    "seed": "tsx --tsconfig backend/tsconfig.json scripts/seed.ts",
    "job:documents": "tsx --tsconfig backend/tsconfig.json scripts/jobs/document-expiry.ts",
    "job:incidents": "tsx --tsconfig backend/tsconfig.json scripts/jobs/incident-escalation.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@supabase/supabase-js": "2.57.4",
    "better-auth": "^1.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "8.16.3",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "22.14.1",
    "@types/pg": "8.15.5",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "tsx": "4.20.5",
    "tsc-alias": "^1.8.10",
    "typescript": "5.8.3",
    "vite": "^7.3.2",
    "vitest": "3.2.4"
  }
}
