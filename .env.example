APP_ENV=development
APP_BASE_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_PORT=4000
APP_CITY=bengaluru
ALLOW_DEV_HEADERS=false
JOB_SECRET=replace_job_secret

# Auth
BETTER_AUTH_SECRET=replace_with_32_plus_char_random_secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_BASE_PATH=/api/auth

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_VEHICLE_IMAGE_BUCKET=vehicle-images

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

# Setu DigiLocker
SETU_DIGILOCKER_BASE_URL=https://dg.setu.co
SETU_CLIENT_ID=replace_me
SETU_CLIENT_SECRET=replace_me
SETU_PRODUCT_INSTANCE_ID=replace_me
SETU_REDIRECT_URL=https://rbabikerentals.com/kyc/callback
SETU_WEBHOOK_SECRET=replace_me
CIBIL_HIGH_RISK_BELOW=650
CIBIL_MEDIUM_RISK_BELOW=700

# Google Maps Platform
GOOGLE_MAPS_API_KEY=replace_me

# Notifications
NOTIFICATION_PROVIDER=mock
WHATSAPP_SENDER_ID=replace_me
SMS_SENDER_ID=replace_me
